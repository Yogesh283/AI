# Copy to .env and set real values. Never commit .env.
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Chat inference (two backends) ---
# `openai` (default) = cloud OpenAI chat/completions (needs OPENAI_API_KEY).
# `local` = your own OpenAI-compatible server (Ollama, vLLM, llama.cpp, etc.).
# NEO_CHAT_BACKEND=openai
#
# When NEO_CHAT_BACKEND=local, set the full completions URL and model id, e.g. Ollama:
# NEO_LOCAL_CHAT_URL=http://127.0.0.1:11434/v1/chat/completions
# NEO_LOCAL_CHAT_MODEL=llama3.1
# Optional bearer if your gateway requires it:
# NEO_LOCAL_CHAT_API_KEY=
#
# Optional: append each successful assistant reply as JSONL for future fine-tuning / distillation
# (does not train anything by itself â€” you run your own offline jobs on this file).
# NEO_TRAINING_LOG_PATH=./data/neo_training.jsonl

# Live voice (OpenAI Realtime WebRTC). Default: gpt-4o-mini-realtime-preview. Override if your key supports another slug (see platform.openai.com/docs/guides/realtime).
# OPENAI_REALTIME_MODEL=gpt-4o-mini-realtime-preview

# Optional: VPS par "ConnectError / all connection attempts failed" ho to outbound HTTPS / DNS check karein.
# Corporate network par HTTPS_PROXY=http://user:pass@host:port bhi kaam aata hai (httpx trust_env=True).
# OPENAI_HTTP_MAX_RETRIES=3

# Comma list; main.py also allows any http://localhost:PORT via regex for Next.js (3000/3001/â€¦)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081
JWT_SECRET=change-this-to-a-long-random-string

# Google Sign-In: Web client ID from Google Cloud (Application type: Web application).
# Use GOOGLE_CLIENT_IDS (comma-separated for Web+Android+iOS) OR a single GOOGLE_CLIENT_ID.
# Must match the client ID used in web/.env.production as NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_IDS=962739296232-s7okf3m6els2for2vj32digur61ms5er.apps.googleusercontent.com
# GOOGLE_CLIENT_ID=962739296232-s7okf3m6els2for2vj32digur61ms5er.apps.googleusercontent.com

# Optional: live web answers (Google Custom Search JSON API). Create a Programmable Search Engine at
# https://programmablesearchengine.google.com/ - enable "Search the entire web", then paste API key + cx.
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=

# Optional: Brave Web Search API for live web snippets (https://brave.com/search/api - set to replace/unlock when Google CSE JSON is blocked)
# BRAVE_SEARCH_API_KEY=

# Optional: SerpAPI key for live web snippets (https://serpapi.com/search — JSON via search.json in code)
# SERPAPI_API_KEY=

# Optional: NewsAPI.org key (https://newsapi.org) — /v2/everything for headlines; good for topics like cricket news
# NEWSAPI_API_KEY=
# Language for NewsAPI articles: en, hi, etc.
# NEWSAPI_LANGUAGE=en
# Google engine localization (optional). Example: India results, Hindi UI, google.co.in:
# SERPAPI_LOCATION=India
# SERPAPI_GOOGLE_DOMAIN=google.co.in
# SERPAPI_HL=hi
# SERPAPI_GL=in
# SERPAPI_DAILY_LIMIT=33

# Optional: Bing Web Search (Azure) — snippets stored in MySQL `live_data`, refreshed on a timer + on user miss
# BING_SEARCH_API_KEY=
# Default v7 URL if empty:
# BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
# LIVE_CACHE_TTL_MINUTES=45
# LIVE_CACHE_CRON_INTERVAL_SECONDS=2700
# With startup prefill + 2700s interval, effective runs are about 33/day.
# Cron topics (comma-separated): SerpAPI then Bing fetch → upsert table `live_data`; append-only table `new_data` only when snippet text changes (hash).
# Prefer LIVE_CRON_QUERIES; if empty, BING_CRON_QUERIES is used.
# LIVE_CRON_QUERIES="ipl-points-table-latest,india-business-news-today,cricket"
# (Always quote the whole value if topics contain spaces.)
# BING_CRON_QUERIES=

# Optional: auto-export MySQL `new_data` rows into a JSONL training corpus (for offline fine-tune/distillation jobs).
# NEW_DATA_TRAINING_EXPORT_PATH=./data/new_data_training.jsonl
# NEW_DATA_TRAINING_EXPORT_INTERVAL_SECONDS=1800

# MySQL (XAMPP) - import sql/init_ai_users.sql in phpMyAdmin, then set MYSQL_DATABASE (and host) to persist chat + usage for logged-in users
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=ai
#
# Older DBs: add `source` on chat_messages for Memory (chat+voice only):
#   mysql -u root -p ai < sql/migration_chat_messages_source.sql

