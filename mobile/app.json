{
  "expo": {
    "name": "NEO",
    "slug": "neo-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/neo-logo.png",
    "scheme": "neo",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/neo-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0E14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.neo.ai.companion"
    },
    "android": {
      "package": "com.neo.ai.companion",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/neo-logo.png",
        "backgroundColor": "#0B0E14"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/neo-logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": "NEO needs the microphone for voice chat."
        }
      ]
    ]
  }
}
