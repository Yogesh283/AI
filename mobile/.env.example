# Match backend/run_dev.ps1 (8010). Change if you use another port.
EXPO_PUBLIC_API_URL=http://127.0.0.1:8010

# Same Web client ID as in Google Cloud (Web application). Used for Expo dev / web target.
# For standalone Android/iOS builds you may add native OAuth clients and set the optional IDs below.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
