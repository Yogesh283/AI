{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/apply-google-signin-patch.cjs",
    "capacitor:copy:after": "node scripts/ensure-android-cordova-plugins-stub.cjs",
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:voice": "npx --yes tsx scripts/test-voice-commands.ts",
    "android:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android-local-dev.ps1",
    "android:local:wifi": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android-local-dev.ps1 -UseLanIp",
    "android:local:api": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android-local-dev.ps1 -ReverseBackend",
    "cap:sync:android:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/cap-sync-local.ps1",
    "cap:sync:android:local:wifi": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/cap-sync-local.ps1 -UseLanIp",
    "cap:sync:android:local:api": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/cap-sync-local.ps1 -ReverseBackend",
    "cap:sync:android:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/cap-sync-production.ps1",
    "android:apk:debug:live": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-live-debug-apk.ps1",
    "apk:release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1 -Flavor both",
    "apk:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1 -AllowDebugSigning -Flavor both",
    "apk:sideload": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1 -AllowDebugSigning -Flavor sideload",
    "apk:play": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1 -AllowDebugSigning -Flavor play"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capawesome/capacitor-google-sign-in": "^0.1.2",
    "@pixiv/three-vrm": "^3.5.2",
    "@react-oauth/google": "^0.13.5",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@types/three": "^0.183.1",
    "framer-motion": "^12.38.0",
    "kalidokit": "^1.1.5",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
