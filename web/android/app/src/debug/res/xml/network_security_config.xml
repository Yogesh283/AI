<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug builds only: allow cleartext HTTP to any host so LAN IP dev
  (e.g. http://192.168.1.5:3000 from cap-sync-local.ps1 -UseLanIp) works
  without listing every private IP in domain-config.
  Release keeps main/res/xml/network_security_config.xml (restricted).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
