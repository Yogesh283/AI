<?xml version="1.0" encoding="utf-8"?>
<!--
  Release / non-debug: HTTPS only. No cleartext localhost tunneling.
  Local dev uses src/debug/res/xml/network_security_config.xml (LAN + tools overlay).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
