# Copy this file to keystore.properties (gitignored) next to this folder.
# Paths for storeFile are relative to web/android/app/ when Gradle resolves file().
#
# Generate a keystore once (example):
#   keytool -genkeypair -v -keystore neo-release.jks -alias neo -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=../neo-release.jks
storePassword=CHANGE_ME
keyAlias=neo
keyPassword=CHANGE_ME
